{
  "expo": {
    "name": "ThronomedICE",
    "slug": "thronomedice",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "thronomedice",
    "platforms": ["ios", "android"],

    "ios": {
      "bundleIdentifier": "io.thronos.medice",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Η εφαρμογή χρησιμοποιεί Bluetooth για σύνδεση με τη συσκευή ThronomedICE και παρακολούθηση ζωτικών σημείων.",
        "NSBluetoothPeripheralUsageDescription": "Η εφαρμογή χρησιμοποιεί Bluetooth για σύνδεση με την ιατρική συσκευή.",
        "UIBackgroundModes": ["bluetooth-central", "remote-notification"],
        "NSFaceIDUsageDescription": "Επαλήθευση ταυτότητας για άνοιγμα της εφαρμογής."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },

    "android": {
      "package": "io.thronos.medice",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2C3E50"
      }
    },

    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["central"],
          "bluetoothAlwaysPermission": "Η εφαρμογή χρησιμοποιεί Bluetooth για σύνδεση με το ThronomedICE."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],

    "splash": {
      "backgroundColor": "#2C3E50"
    },

    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
